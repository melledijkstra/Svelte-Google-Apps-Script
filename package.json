{
  "name": "svelte-google-apps-script",
  "version": "1.0.0",
  "author": "Melle Dijkstra",
  "description": "A template for building Google Apps Scripts using Svelte and Vite.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": "22"
  },
  "scripts": {
    "serve": "vite",
    "dev": "pnpm build:dev && pnpm push && pnpm serve",
    "build": "vite build --mode production",
    "build:dev": "NODE_ENV=development vite build --mode production",
    "release": "pnpm build && pnpm push",
    "release:dev": "pnpm build:dev && pnpm push",
    "push": "clasp push -f",
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "local:ci": "pnpm lint && pnpm build && vitest run",
    "setup:https": "mkdir certs && mkcert -key-file ./certs/key.pem -cert-file ./certs/cert.pem localhost 127.0.0.1",
    "switch-env": "tsx ./scripts/switch-env.ts"
  },
  "dependencies": {
    "svelte": "^5.54.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "^3.3.0",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-links": "^10.3.1",
    "@storybook/addon-svelte-csf": "^5.0.12",
    "@storybook/svelte": "^10.3.3",
    "@storybook/svelte-vite": "^10.3.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "gas-client": "^1.2.1",
    "gas-types-detailed": "^1.1.3",
    "rollup": "^4.60.0",
    "storybook": "^10.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melledijkstra/svelte-google-apps-script.git"
  },
  "keywords": [
    "google-apps-script",
    "typescript",
    "svelte",
    "vite",
    "automation",
    "script",
    "sheet",
    "google"
  ],
  "bugs": {
    "url": "https://github.com/melledijkstra/svelte-google-apps-script/issues"
  }
}
